    {
      "id": "6b13162a-897f-4fe1-b7b9-734f8e4b7413",
      "name": "👋 Envoyer Message Bienvenue",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-3168, 2624],
      "parameters": {
        "method": "POST",
        "url": "=https://YOUR_EVOLUTION_API_URL/message/sendText/YOUR_INSTANCE_NAME",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "number", "value": "={{ $('🔍 Extraire Message & Téléphone').item.json.phone }}" },
            { "name": "text", "value": "Bonjour et bienvenue chez MediFlow ! 👋\n\nJe suis MediBot, votre assistant pour la prise de rendez-vous médicaux.\n\nComment puis-je vous aider aujourd'hui ? Vous pouvez me dire par exemple :\n- \"Je veux prendre un rendez-vous\"\n- \"Je veux annuler mon rendez-vous\"\n- \"J'ai une urgence médicale\"" }
          ]
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Evolution API — MediFlow"
        }
      }
    },
    {
      "id": "5449abe4-aa9a-48ce-91ed-ef2e811f5401",
      "name": "📋 Lire État Conversation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-3296, 2176],
      "parameters": {
        "jsCode": "// Récupère l'état de conversation persisté en Google Sheets\nconst patientData = $('👤 Chercher Patient (Google Sheets)').item.json;\nconst messageData = $('🔍 Extraire Message & Téléphone').item.json;\n\nconst etatConv = patientData.etat_conversation || 'LIBRE';\nconst creneauxProposes = patientData.creneaux_proposes || '';\n\nreturn [{\n  json: {\n    phone: messageData.phone,\n    message: messageData.message,\n    patient_id: patientData.patient_id || '',\n    patient_prenom: patientData.prenom || '',\n    etat_conversation: etatConv,\n    creneaux_proposes: creneauxProposes\n  }\n}];"
      }
    },
    {
      "id": "cf75af23-5df4-4204-b086-ec6c1d4acc28",
      "name": "⏳ En attente de choix ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [-3072, 2176],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.etat_conversation }}",
              "rightValue": "ATTENTE_CRENEAU",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      }
    },
    {
      "id": "64c5a635-42d6-45d6-a51b-5cbd49937397",
      "name": "Prépare Requête Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-2944, 2912],
      "parameters": {
        "jsCode": "// Construit le prompt Claude selon l'état de conversation\nconst etat = $('📋 Lire État Conversation').item.json.etat_conversation || 'LIBRE';\nconst message = $('📋 Lire État Conversation').item.json.message || '';\n\nconst body = {\n  model: \"claude-haiku-4-5-20251001\",\n  max_tokens: 600,\n  system: `Tu es MediBot, l'assistant de prise de rendez-vous d'une clinique privée.\n\nServices : cardiologie, pédiatrie, généraliste, gynécologie, dermatologie.\nÉtat conversation : ${etat}\n\nRÈGLES :\n1. RDV sans spécialité → retourne PRENDRE_RDV, specialite=null, liste les spécialités dans message_reponse\n2. État ATTENTE_SPECIALITE → le message est la spécialité choisie\n3. Spécialité précisée → retourne PRENDRE_RDV avec specialite renseignée\n4. Urgence → retourne URGENCE\n5. Autre → retourne AUTRE avec réponse utile\n\nRetourne UNIQUEMENT un JSON valide :\n{\n  \"intention\": \"PRENDRE_RDV\" | \"ANNULER_RDV\" | \"CONFIRMER_RDV\" | \"URGENCE\" | \"AUTRE\",\n  \"specialite\": null | \"cardiologie\" | \"pédiatrie\" | \"généraliste\" | \"gynécologie\" | \"dermatologie\",\n  \"message_reponse\": \"message chaleureux en français\",\n  \"demander_specialite\": false\n}`,\n  messages: [{ role: \"user\", content: \"Message du patient : \" + message }]\n};\n\nreturn [{ json: { claudeBody: JSON.stringify(body) } }];"
      }
    },
    {
      "id": "177206be-e2e0-4625-997c-7481e8472dd2",
      "name": "🤖 Claude — Analyser Intention",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-2704, 2912],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "anthropicApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.parse($json.claudeBody) }}",
        "options": { "timeout": 30000 }
      },
      "credentials": {
        "anthropicApi": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Anthropic — MediFlow"
        }
      }
    },
    {
      "id": "68b7a017-3d1e-46b1-9b5b-e9e90f99d208",
      "name": "⚙️ Parser Réponse Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-2496, 2912],
      "parameters": {
        "jsCode": "// Parse la réponse JSON de Claude et attache les données patient\nconst response = $input.first().json;\nlet claudeData = {};\n\ntry {\n  const rawText = response.content[0].text;\n  const cleaned = rawText.replace(/```json|```/g, '').trim();\n  claudeData = JSON.parse(cleaned);\n} catch(e) {\n  claudeData = {\n    intention: 'AUTRE',\n    message_reponse: 'Bonjour ! Je suis MediBot, votre assistant. Comment puis-je vous aider ?',\n    demander_specialite: false\n  };\n}\n\nclaudeData.phone = $('📋 Lire État Conversation').item.json.phone;\nclaudeData.patient_id = $('📋 Lire État Conversation').item.json.patient_id;\nclaudeData.patient_prenom = $('📋 Lire État Conversation').item.json.patient_prenom;\n\nreturn [{ json: claudeData }];"
      }
    },
