      "id": "89870dba-36e7-42d1-bfc7-ab861990eae7",
      "name": "🔀 Router par Intention",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [-2304, 2848],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.intention }}", "rightValue": "URGENCE", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "conditions": {
                "conditions": [
                  { "leftValue": "={{ $json.intention }}", "rightValue": "PRENDRE_RDV", "operator": { "type": "string", "operation": "equals" } },
                  { "leftValue": "={{ $json.specialite }}", "rightValue": "", "operator": { "type": "string", "operation": "notEmpty", "singleValue": true } }
                ]
              }
            },
            {
              "conditions": {
                "conditions": [{ "leftValue": "={{ $json.intention }}", "rightValue": "ANNULER_RDV", "operator": { "type": "string", "operation": "equals" } }]
              }
            }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      }
    },
